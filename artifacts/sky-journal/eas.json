{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "node": "22.0.0",
      "pnpm": "10.26.1",
      "env": {
        "PRODUCTION_API_URL": "https://loom-qasiland.replit.app/api"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    },
    "production-apk": {
      "node": "22.0.0",
      "pnpm": "10.26.1",
      "env": {
        "PRODUCTION_API_URL": "https://loom-qasiland.replit.app/api"
      },
      "android": {
        "buildType": "apk"
      }
    }
  }
}
