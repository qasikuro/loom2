{
  "expo": {
    "name": "GameJo",
    "slug": "sky-journal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/gamejo_logo.png",
    "scheme": "sky-journal",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/gamejo_splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0D0B1E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gamejo.app"
    },
    "android": {
      "package": "com.gamejo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/gamejo_logo.png",
        "backgroundColor": "#0D0B1E"
      }
    },
    "web": {
      "favicon": "./assets/images/gamejo_logo.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GameJo to access your photos to add images to your logs."
        }
      ]
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
